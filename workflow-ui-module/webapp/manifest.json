{
    "_version": "1.26.0",
    "sap.app": {
        "id": "cash.workflowuimodule",
        "type": "application",
        "i18n": "i18n/i18n.properties",
        "applicationVersion": {
            "version": "0.0.1"
        },
        "title": "{{appTitle}}",
        "description": "{{appDescription}}",
        "resources": "resources.json",
        "sourceTemplate": {
            "id": "@sap/generator-fiori:basic",
            "version": "1.8.4",
            "toolsId": "513e44c4-52d5-43cf-90c3-25f386c7e448"
        },
        "dataSources": {
            "mainService": {
                "uri": "/sap/opu/odata/",
                "type": "OData",
                "settings": {
                    "annotations": [],
                    "localUri": "localService/metadata.xml",
                    "odataVersion": "2.0"
                }
            }
        }
    },
    "sap.ui": {
        "technology": "UI5",
        "icons": {
            "icon": "",
            "favIcon": "",
            "phone": "",
            "phone@2": "",
            "tablet": "",
            "tablet@2": ""
        },
        "deviceTypes": {
            "desktop": true,
            "tablet": true,
            "phone": true
        }
    },
    "sap.ui5": {
        "flexEnabled": true,
        "dependencies": {
            "minUI5Version": "1.82.2",
            "libs": {
                "sap.m": {},
                "sap.ui.core": {},
                "sap.f": {},
                "sap.suite.ui.generic.template": {},
                "sap.ui.comp": {},
                "sap.ui.generic.app": {},
                "sap.ui.table": {},
                "sap.ushell": {}
            }
        },
        "contentDensities": {
            "compact": true,
            "cozy": true
        },
        "models": {
            "i18n": {
                "type": "sap.ui.model.resource.ResourceModel",
                "settings": {
                    "bundleName": "cash.workflowuimodule.i18n.i18n"
                }
            },
            "": {
                "dataSource": "mainService",
                "preload": true,
                "settings": {}
            }
        },
        "resources": {
            "css": [
                {
                    "uri": "css/style.css"
                }
            ]
        },
        "routing": {
            "config": {
                "routerClass": "sap.m.routing.Router",
                "viewType": "XML",
                "async": true,
                "viewPath": "cash.workflowuimodule.view",
                "controlAggregation": "pages",
                "controlId": "app",
                "clearControlAggregation": false
            },
            "routes": [
                {
                    "name": "RouteMyTaskUI",
                    "pattern": ":?query:",
                    "target": [
                        "TargetMyTaskUI"
                    ]
                }
            ],
            "targets": {
                "TargetMyTaskUI": {
                    "viewType": "XML",
                    "transition": "slide",
                    "clearControlAggregation": false,
                    "viewId": "MyTaskUI",
                    "viewName": "MyTaskUI"
                }
            }
        },
        "rootView": {
            "viewName": "cash.workflowuimodule.view.App",
            "type": "XML",
            "async": true,
            "id": "App"
        }
    },
    "sap.cloud": {
        "public": true,
        "service": "cash"
    },

   "sap.bpa.task": {
  "_version": "1.0.0",
  "category": "approval",

  "outcomes": [
    { "id": "approve", "label": "Approve" },
    { "id": "reject", "label": "Reject" }
  ],

  "inputs": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "Disbursement Details",
    "type": "object",
    "required": [
      "capital",
      "earmarkFundDocuments",
      "disbursements"
    ],
    "properties": {
      "capital": {
        "type": "object",
        "required": ["disbursementObligation"],
        "properties": {
          "disbursementObligation": {
            "type": "string",
            "title": "Disbursement Obligation"
          }
        }
      },

      "earmarkFundDocuments": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "documentLine",
            "loanCategory",
            "flowType",
            "originalAmount",
            "text",
            "fund",
            "budgetPeriod",
            "glAccount",
            "completionIndicator",
            "selectAccountCoding"
          ],
          "properties": {
            "documentLine": { "type": "string" },
            "loanCategory": { "type": "string" },
            "flowType": { "type": "string" },
            "originalAmount": { "type": "number" },
            "text": { "type": "string" },
            "fund": { "type": "string" },
            "budgetPeriod": { "type": "string" },
            "glAccount": { "type": "string" },
            "completionIndicator": { "type": "string" },
            "selectAccountCoding": { "type": "string" }
          }
        }
      },

      "disbursements": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "lineItem",
            "newDisburseAmount",
            "paymentDate",
            "effectiveDate",
            "paymentMethod",
            "houseBank",
            "bankDetails"
          ],
          "properties": {
            "lineItem": { "type": "string" },
            "newDisburseAmount": { "type": "number" },
            "paymentDate": { "type": "string", "format": "date" },
            "effectiveDate": { "type": "string", "format": "date" },
            "paymentMethod": { "type": "string" },
            "houseBank": { "type": "string" },
            "bankDetails": { "type": "string" }
          }
        }
      }
    }
  },

  "outputs": {
    "$schema": "http://json-schema.org/draft-07/schema",
    "title": "output",
    "type": "object",
    "properties": {
      "decision": {
        "type": "string"
      }
    }
  }
}

    
}